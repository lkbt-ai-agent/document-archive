# Local AI provider configuration for llama.cpp.
# Copy values into your local shell, .env file, or process manager.
# Do not commit machine-specific model paths.

# Fallback endpoint used when a provider-specific endpoint is not set.
LLAMA_CPP_BASE_URL=http://127.0.0.1:8080

# Optional provider-specific endpoints. Use these when running separate
# llama.cpp server processes for OCR, embeddings, and generation.
LLAMA_CPP_OCR_BASE_URL=http://127.0.0.1:8081
LLAMA_CPP_EMBEDDING_BASE_URL=http://127.0.0.1:8082
LLAMA_CPP_GENERATION_BASE_URL=http://127.0.0.1:8083

# OCR and image analysis: Qwen2.5-VL-7B-Instruct GGUF plus projector file.
LOCAL_AI_OCR_MODEL_NAME=Qwen2.5-VL-7B-Instruct
LOCAL_AI_OCR_MODEL_PATH=/absolute/path/to/models/ocr/qwen2.5-vl-7b-instruct.gguf
LOCAL_AI_OCR_MMPROJ_PATH=/absolute/path/to/models/ocr/mmproj-qwen2.5-vl-7b-instruct.gguf

# Embeddings and semantic search: BGE-M3 GGUF.
LOCAL_AI_EMBEDDING_MODEL_NAME=BGE-M3
LOCAL_AI_EMBEDDING_MODEL_PATH=/absolute/path/to/models/embedding/bge-m3.gguf

# Summarization, tagging, document generation, and document merge: Qwen3-14B GGUF.
LOCAL_AI_GENERATION_MODEL_NAME=Qwen3-14B
LOCAL_AI_GENERATION_MODEL_PATH=/absolute/path/to/models/generation/qwen3-14b.gguf
